body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0b0b0b;
  color: #fff;
}

.header {
  display: flex;
  justify-content: space-between;
  padding: 20px;
  background: rgba(0,0,0,0.8);
  position: fixed;
  width: 100%;
}

.logo {
  color: #e50914;
}

nav a {
  color: white;
  margin-left: 20px;
  text-decoration: none;
}

.hero {
  height: 100vh;
  background: url('https://images.unsplash.com/photo-1524985069026-dd778a71c7b4') center/cover;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
}

.hero-content {
  position: relative;
  text-align: center;
  animation: fadeIn 2s;
}

.hero h2 {
  font-size: 40px;
}

.btn {
  display: inline-block;
  margin-top: 20px;
  padding: 15px 30px;
  background: #e50914;
  color: white;
  text-decoration: none;
  border-radius: 5px;
}

.section {
  padding: 80px 20px;
  text-align: center;
}

.dark {
  background: #111;
}

.grid {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 40px;
  flex-wrap: wrap;
}

.box, .card {
  background: #1a1a1a;
  padding: 30px;
  border-radius: 10px;
  width: 250px;
  transition: 0.3s;
}

.box:hover, .card:hover {
  transform: scale(1.05);
}

.price {
  font-size: 30px;
  margin: 10px 0;
}

.destaque {
  border: 2px solid #e50914;
}

button {
  padding: 10px 20px;
  background: #e50914;
  border: none;
  color: white;
  cursor: pointer;
}

footer {
  padding: 20px;
  text-align: center;
  background: black;
}

@keyframes fadeIn {
  from {opacity: 0;}
  to {opacity: 1;}
}
function whatsapp() {
  const numero = "5511999999999"; // coloque seu número aqui
  const mensagem = "Quero testar a CineTV agora!";
  const url = `https://wa.me/${numero}?text=${encodeURIComponent(mensagem)}`;
  
  window.open(url, "_blank");
}
